# 顶栏环境标识（十五-09）；构建时注入，可随部署环境修改。
UMI_APP_ENV_LABEL=开发

# 可选（十五-24）：Grafana 根 URL，构建注入后工作台展示「打开 Grafana」外链。
# UMI_APP_GRAFANA_URL=https://grafana.example.com

# 可选（P5）：非空时登录/注册走独立 IAM；生产需 nginx 反代 ``/iam-api``（见 deploy/nginx/console-spa.conf.template）。
# UMI_APP_IAM_PREFIX=/iam-api

# 仅 ``npm run dev``：Umi proxy 指向控制面 / IAM（默认本机 8000 / 8100）。与 Docker 运行时 **DEVAULT_CONSOLE_*_UPSTREAM** 无关。
# UMI_DEV_API_ORIGIN=http://127.0.0.1:8000
# UMI_DEV_IAM_ORIGIN=http://127.0.0.1:8100
