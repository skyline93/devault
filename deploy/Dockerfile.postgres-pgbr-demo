# Demo-only: PostgreSQL 14 + sshd so pgBackRest on another container can use default pg-host-type=ssh.
FROM postgres:14
USER root
# 默认 apt：阿里云 Debian；PGDG 仍走 apt.postgresql.org（阿里云路径与官方不一致，避免 404）
RUN set -eux; \
    for f in /etc/apt/sources.list /etc/apt/sources.list.d/*; do \
      [ -f "$f" ] || continue; \
      sed -i 's|https://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' "$f"; \
      sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' "$f"; \
      sed -i 's|https://deb.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' "$f"; \
      sed -i 's|http://deb.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' "$f"; \
      sed -i 's|https://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' "$f"; \
      sed -i 's|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' "$f"; \
    done
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends openssh-server \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/run/sshd \
    && mkdir -p /var/lib/postgresql/.ssh \
    && chown postgres:postgres /var/lib/postgresql/.ssh \
    && chmod 700 /var/lib/postgresql/.ssh \
    && sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config \
    && printf '\nAllowUsers postgres\n' >> /etc/ssh/sshd_config
COPY deploy/pgbr-demo/authorized_keys /var/lib/postgresql/.ssh/authorized_keys
RUN chown postgres:postgres /var/lib/postgresql/.ssh/authorized_keys && chmod 600 /var/lib/postgresql/.ssh/authorized_keys
COPY deploy/pgbr-demo/docker-entrypoint-postgres-pgbr.sh /usr/local/bin/docker-entrypoint-postgres-pgbr.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-postgres-pgbr.sh
ENTRYPOINT ["/usr/local/bin/docker-entrypoint-postgres-pgbr.sh"]
