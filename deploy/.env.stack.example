# 复制为 deploy/.env 后由 ``docker compose`` 自动加载（在 deploy 目录执行 compose 时）。
# cp deploy/.env.stack.example deploy/.env
#
# Compose profiles（可选）：不设时请在命令行传 ``--profile …``。等价示例：
#   COMPOSE_PROFILES=with-control-plane,with-agent,with-console,with-monitoring
# 无 profile 时仅启动 postgres / redis / minio / minio-init；说明见 docker-compose.yml 文件头。

# --- 控制面镜像（推荐本地构建以包含最新迁移，含 IAM 默认租户 UUID 对齐）---
DEVAULT_IMAGE=devault:local
DEVAULT_CONSOLE_IMAGE=devault-console:local

# --- IAM 与 DeVault API 的 JWT 声明（须与 iam 服务环境变量一致）---
# 浏览器经宿主访问 IAM 时用 127.0.0.1，与令牌内 iss 一致。
IAM_JWT_ISSUER=http://127.0.0.1:8100
IAM_JWT_AUDIENCE=devault-api
DEVAULT_IAM_JWT_ISSUER=http://127.0.0.1:8100
DEVAULT_IAM_JWT_AUDIENCE=devault-api
# 容器内 JWKS 地址（api 访问 iam 服务名）
DEVAULT_IAM_JWKS_URL=http://iam:8100/.well-known/jwks.json

# --- Console 构建期：同源 IAM 路径（nginx 模板 /iam-api/ 与之一致）---
UMI_APP_IAM_PREFIX=/iam-api
# 认证排查日志：未传或传 1 时默认开启；显式关闭：UMI_APP_AUTH_DEBUG=0（或 false/off/no）。Dockerfile.console 默认 ARG=1。
UMI_APP_AUTH_DEBUG=1

# --- Console 运行时：nginx 反代上游（默认已是 api:8000 / iam:8100，一般无需改）---
# DEVAULT_CONSOLE_API_UPSTREAM=api:8000
# DEVAULT_CONSOLE_IAM_UPSTREAM=iam:8100

# --- 演示栈：IAM 自动 bootstrap 平台用户 + demo-stack-init 登录用（与 iam 服务默认值一致；生产请改写）---
# IAM_DEMO_AUTO_BOOTSTRAP=true
# DEMO_STACK_PLATFORM_EMAIL=demo@devault.com
# DEMO_STACK_PLATFORM_PASSWORD=Devault12345

# --- Agent / 远程 MinIO：若 Agent 在宿主机或非 compose 网络，需改为宿主机可达地址 ---
# DEVAULT_S3_ENDPOINT=http://host.docker.internal:9000

# --- 可选：对象存储桶名 ---
# DEVAULT_S3_BUCKET=devault

# --- 演示栈：demo-stack-init 在 with-agent/with-console 下可选自动签发 Agent 令牌（HTTP）---
# DEMO_STACK_SKIP_AGENT_TOKEN_BOOTSTRAP=false
# DEMO_STACK_AGENT_TOKEN_LABEL=demo-stack-agent
# DEMO_STACK_AGENT_TOKEN_FILE=/shared/demo-agent-token
# DEMO_STACK_AGENT2_TOKEN_LABEL=demo-stack-agent-2
# DEMO_STACK_AGENT2_TOKEN_FILE=/shared/demo-agent-token-2

# --- 演示栈：pgBackRest 目标库 + 自动策略（with-agent profile；见 website pgBackRest 附录 A）---
# DEMO_STACK_PGBR_ENABLED=true
# DEMO_STACK_PGBR_MIN_AGENTS=2
# DEMO_STACK_PGBR_AGENT_INDEX=1
# DEMO_PGBR_STANZA=demo
# DEVAULT_AGENT_TOKEN=
# DEVAULT_AGENT2_TOKEN=
